---
import { Users } from 'lucide-react';
import { YourLink } from './YourLink';
import { YourName } from './YourName';
---

<main class='relative h-screen w-screen overflow-hidden'>
  {/* Subtle gradient background */}
  <div class='absolute inset-0'>
    <div
      class='absolute top-0 left-1/2 -translate-x-1/2 w-200 h-100 bg-white/[0.02] rounded-full blur-[120px]'
    >
    </div>
  </div>

  {/* Dot pattern */}
  <div
    class='absolute inset-0 opacity-[0.4]'
    style={{
      backgroundImage: `radial-gradient(rgba(255,255,255,0.07) 1px, transparent 1px)`,
      backgroundSize: '24px 24px',
    }}
  >
  </div>

  {/* Content */}
  <div
    class='relative z-0 flex flex-col items-center justify-center h-full px-6'
  >
    {/* Logo */}
    <div class='flex items-center gap-2.5 mb-12'>
      <div class='w-8 h-8'>
        <img src='favicon.svg' alt='' />
      </div>
      <span class='text-lg font-medium text-white/90 tracking-tight'>
        ahiseve
      </span>
    </div>

    {/* Main card */}
    <div class='w-full max-w-xs'>
      <div class='bg-white/[0.03] border border-white/[0.06] rounded-2xl p-5'>
        <div class='flex justify-center mb-5'>
          <button
            class='flex items-center justify-center gap-2 text-sm font-medium text-white'
          >
            <Users className='w-4 h-4' />
            Invitar
          </button>
        </div>
        <YourLink client:load />
      </div>
    </div>

    <YourName client:load />
  </div>
</main>
