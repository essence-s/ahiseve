---
interface Props {
  title: string;
}

const { title } = Astro.props;
// import '@fontsource/poppins';
import '@fontsource-variable/inter';
import Toast from '@/components/Toast.astro';
// import { ViewTransitions } from "astro:transitions";
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { PeerConnection } from '@/components/PeerConnection/PeerConnection';
import TabLock from '@/components/TabLock';
---

<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='description' content='Astro description' />
    <meta name='viewport' content='width=device-width' />
    <link rel='icon' type='image/svg+xml' href='/favicon.svg' />
    <meta name='generator' content={Astro.generator} />
    <title>{title}</title>
    <!-- <ViewTransitions /> -->
    <ClientRouter />
  </head>
  <body class='dark'>
    {/* Subtle gradient background */}
    <div class='absolute inset-0 overflow-hidden'>
      <div
        class='absolute top-50 left-1/2 -translate-x-1/2 w-120 h-120 bg-[#d3d3d60c] rounded-full blur-[80px]'
      >
      </div>
    </div>
    {/* Dot pattern */}
    <div
      class='absolute inset-0 opacity-[0.4]'
      style={{
        backgroundImage: `radial-gradient(rgba(255,255,255,0.07) 1px, transparent 1px)`,
        backgroundSize: '24px 24px',
      }}
    >
    </div>
    <PeerConnection client:load transition:persist />
    <TabLock client:load transition:persist />
    <slot />
    <Toast />
    <style is:global>
      :root {
        --primary-color: #cd2a48;
        --secondary-color: #f7dc6d;
        --accent-color: #1b1a25;
        --text-primary: #ececec;
        --text-secondary: #0e0e0e;
        --bg-primary: #133a4a;
        --list-primary: #f7dc6d;
        --list-secondary: rgb(43, 41, 58);

        --border-color: #ffffff12;
        --link-color: #2150a8;
        --disabled-color: #474747;
        --circle-dash: #f1d84b52;

        /* Tipografy */
        --font-family: 'Inter Variable';
        --font-size-default: 0.8rem;
        --font-size-large: 1rem;
        --font-size-small: 0.69rem;
        --line-height: 1;

        /* Space Size */
        --spacing-unit: #000000;
        --border-radius: 15px;
        --border-radius-secondary: 10px;

        /* Shadows */
        --box-shadow: 5px 5px 5px 0px #00000030;

        --border1px: solid 1px var(--border-color);
      }
      * {
        box-sizing: border-box;
        -webkit-tap-highlight-color: transparent;

        tap-highlight-color: transparent;
      }
      html {
        background: #21282b;
      }
      body {
        color: white;
        font-family: var(--font-family), sans-serif;
        font-size: var(--font-size-default);
        line-height: var(--line-height);
        margin: 0;
        padding: 0;
        height: 100vh;
        width: 100vw;
        overflow: hidden;
      }

      h1 {
        font-size: 16px;
        /* font-family: sans-serif; */
      }

      *::-webkit-scrollbar {
        width: 6px;
      }

      *::-webkit-scrollbar-track {
        background: #23272c;
        border-radius: 15px;
        padding: 3px;
      }

      *::-webkit-scrollbar-thumb {
        background: #55555e;
        border-radius: 15px;
        border: solid 1px #ffffff10;
      }
    </style>
  </body>
</html>
